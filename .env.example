# Copie ce fichier en .env et remplis les valeurs.
# cp .env.example .env

# 42 OAuth app — https://profile.intra.42.fr/oauth/applications
FT_OAUTH_UID=
FT_OAUTH_SECRET=
FT_OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback

# Backend
PORT=3000

# Cookie session signing — génère un nouveau secret :
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Postgres (plus tard, quand on branche Prisma)
# DATABASE_URL=postgresql://league:league@localhost:5432/league
