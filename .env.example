# Copie ce fichier en .env et remplis les valeurs.
# cp .env.example .env

# 42 OAuth app — https://profile.intra.42.fr/oauth/applications
FT_OAUTH_UID=
FT_OAUTH_SECRET=
FT_OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback

# Backend
PORT=3000

# Web app — origines autorisées pour CORS + redirect_to du flow /auth/web/login.
# Comma-separated. En prod, ajoute l'URL Vercel : https://42-league.vercel.app
WEB_APP_URLS=http://localhost:5173

# Cookie session signing — génère un nouveau secret :
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Postgres (plus tard, quand on branche Prisma)
# DATABASE_URL=postgresql://league:league@localhost:5432/league
