www.42league.fr {
    redir https://42league.fr{uri} permanent
}

42league.fr {
    # Headers de durcissement appliqués à toutes les réponses (front + API).
    # Vérifiés quotidiennement par .github/workflows/daily-security-audit.yml.
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    handle /api/* {
        uri strip_prefix /api
        reverse_proxy backend:3000 {
            # Flush immédiat : indispensable pour le flux SSE (/api/events),
            # sinon Caddy bufferise et les events n'arrivent qu'à la fermeture.
            flush_interval -1
        }
    }
    handle {
        reverse_proxy frontend:80
    }
}

# ── STAGING ───────────────────────────────────────────────────────────────────
# Même Caddy, second domaine. Caddy provisionne automatiquement le certificat
# TLS de staging.42league.fr dès que le DNS pointe sur le VPS (aucun certbot).
# Les upstreams `league-stg-*` sont atteints via le réseau partagé `league_edge`.
staging.42league.fr {
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        Referrer-Policy "strict-origin-when-cross-origin"
        # Empêche l'indexation du staging par les moteurs de recherche.
        X-Robots-Tag "noindex, nofollow"
        -Server
    }

    # Mur d'authentification HTTP Basic : tout le staging est privé.
    # Le hash bcrypt est injecté via l'environnement (fichier caddy.env, jamais
    # commité). Générer avec : docker run --rm caddy:alpine caddy hash-password --plaintext 'MotDePasse'
    basic_auth {
        admin {$STAGING_BASICAUTH_HASH}
    }

    handle /api/* {
        uri strip_prefix /api
        reverse_proxy league-stg-backend:3000 {
            flush_interval -1
        }
    }
    handle {
        reverse_proxy league-stg-frontend:80
    }
}
