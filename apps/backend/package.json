{
  "name": "@42-league/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "start": "tsx --env-file=../../.env src/index.ts",
    "test": "vitest run --passWithNoTests",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "typecheck": "tsc --noEmit",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:reset": "dotenv -e ../../.env -- prisma migrate reset",
    "db:seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "db:add-notif": "dotenv -e ../../.env -- tsx prisma/add-test-notif.ts",
    "db:seed-test": "dotenv -e ../../.env -- tsx prisma/seed-test.ts",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "db:generate": "dotenv -e ../../.env -- prisma generate"
  },
  "dependencies": {
    "@42-league/shared": "*",
    "@hono/node-server": "^1.13.7",
    "@prisma/client": "^5.22.0",
    "hono": "^4.6.14",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8"
  }
}
