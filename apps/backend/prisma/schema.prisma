generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  SUPERADMIN
}

model User {
  login           String    @id
  ftId            Int?      @unique @map("ft_id")
  campus          String?
  imageUrl        String?   @map("image_url")
  title           String?
  role            Role      @default(USER)
  elo             Int       @default(1000)
  matchesPlayed   Int       @default(0) @map("matches_played")
  dodgeCount      Int       @default(0) @map("dodge_count")
  tournamentsWon  Int       @default(0) @map("tournaments_won")
  // Classement Smash Bros (jeu parallèle) — rating/compteurs distincts du babyfoot.
  eloSmash            Int   @default(1000) @map("elo_smash")
  matchesPlayedSmash  Int   @default(0)    @map("matches_played_smash")
  tournamentsWonSmash Int   @default(0)    @map("tournaments_won_smash")
  // Classement Échecs (3e discipline).
  eloChess            Int   @default(1000) @map("elo_chess")
  matchesPlayedChess  Int   @default(0)    @map("matches_played_chess")
  tournamentsWonChess Int   @default(0)    @map("tournaments_won_chess")
  // Classement Street Fighter (4e discipline, mécaniquement identique au Smash).
  eloSf               Int   @default(1000) @map("elo_sf")
  matchesPlayedSf     Int   @default(0)    @map("matches_played_sf")
  tournamentsWonSf    Int   @default(0)    @map("tournaments_won_sf")
  // Porte-monnaie « League Coin » — solde dépensable dans la boutique (cf. ShopItem).
  leagueCoins         Int   @default(0) @map("league_coins")
  // Modes auxquels le joueur adhère (apparaît dans les stats/classements du mode).
  games               String[] @default(["babyfoot"])
  onboardedAt         DateTime? @map("onboarded_at") // a choisi ses modes (1er login)
  bannedAt        DateTime? @map("banned_at")
  anonymizedAt    DateTime? @map("anonymized_at")
  deletionScheduledAt DateTime? @map("deletion_scheduled_at")
  // Preuve du consentement RGPD (CGU API 42, Art. 4.2). `termsAcceptedAt` = date
  // d'acceptation ; `termsVersion` = version de la politique acceptée. Si la
  // politique évolue, termsVersion ne correspond plus → le consentement est
  // re-demandé. Tant que le consentement n'est pas donné, la consent-gate
  // (cf. index.ts) refuse tout traitement de données 42 côté serveur (403).
  termsAcceptedAt DateTime? @map("terms_accepted_at")
  termsVersion    String?   @map("terms_version")
  createdAt       DateTime  @default(now()) @map("created_at")

  declaredPending     PendingMatch[]     @relation("declarer")
  awaitingPending     PendingMatch[]     @relation("opponent")
  matchesAsA          PlayedMatch[]      @relation("playerA")
  matchesAsB          PlayedMatch[]      @relation("playerB")
  // 2v2 Babyfoot — second player of each team side.
  matchesAsA2         PlayedMatch[]      @relation("playerA2")
  matchesAsB2         PlayedMatch[]      @relation("playerB2")
  pendingAsPartner1   PendingMatch[]     @relation("pendingPartner1")
  pendingAsPartner2   PendingMatch[]     @relation("pendingPartner2")
  challengesSent      Challenge[]        @relation("challenger")
  challengesReceived  Challenge[]        @relation("opponentChallenge")
  tournamentsCreated  Tournament[]       @relation("tournamentCreator")
  tournamentsWonRel   Tournament[]       @relation("tournamentWinner")
  tournamentEntries   TournamentEntry[]
  tournamentMatchesA  TournamentMatch[]  @relation("tournPlayerA")
  tournamentMatchesB  TournamentMatch[]  @relation("tournPlayerB")
  opsAsOwner          Ops[]              @relation("opsOwner")
  opsAsTarget         Ops[]              @relation("opsTarget")
  tournamentInvitesSent     TournamentInvite[] @relation("tournamentInvitesSent")
  tournamentInvitesReceived TournamentInvite[] @relation("tournamentInvitesReceived")
  featureRequests     FeatureRequest[]
  bugReports          BugReport[]
  rejectedAsDeclarer  RejectedMatch[]    @relation("rejectedDeclarer")
  rejectedAsOpponent  RejectedMatch[]    @relation("rejectedOpponent")
  notifications       Notification[]     @relation("notif")
  badges              UserBadge[]        @relation("userBadges")
  following           Follow[]           @relation("following")
  followers           Follow[]           @relation("followers")
  // BabyfootTeam — duos 2v2 dont ce joueur fait partie.
  babyfootTeamsAsP1   BabyfootTeam[]     @relation("babyfootTeamPlayer1")
  babyfootTeamsAsP2   BabyfootTeam[]     @relation("babyfootTeamPlayer2")
  // Boutique — cosmétiques possédés par le joueur (titres, bannières…).
  inventory           ShopInventory[]    @relation("userInventory")

  @@map("users")
}

model Follow {
  id               String   @id @default(uuid())
  followerLogin    String   @map("follower_login")
  followeeLogin    String   @map("followee_login")
  // Préférences de notification par personne suivie.
  notifyTournament Boolean  @default(true) @map("notify_tournament")
  notifyTop3       Boolean  @default(true) @map("notify_top3")
  notifyTrophy     Boolean  @default(true) @map("notify_trophy")
  notifyOps        Boolean  @default(true) @map("notify_ops")
  createdAt        DateTime @default(now()) @map("created_at")

  follower User @relation("following", fields: [followerLogin], references: [login], onDelete: Cascade, onUpdate: Cascade)
  followee User @relation("followers", fields: [followeeLogin], references: [login], onDelete: Cascade, onUpdate: Cascade)

  @@unique([followerLogin, followeeLogin])
  @@index([followeeLogin])
  @@map("follows")
}

model UserBadge {
  id        String   @id @default(uuid())
  userLogin String   @map("user_login")
  code      String   // code du badge (cf. catalogue front), ex. 'beta_tester', 'season_champion'
  seasonId  String?  @map("season_id") // saison associée (badges de palmarès), si pertinent
  // Discipline liée ('' = badge global, 'babyfoot'/'smash'/'chess' = spécifique).
  // Permet de distinguer un champion babyfoot et un champion chess sur la même saison.
  game      String   @default("") // '' | 'babyfoot' | 'smash' | 'chess'
  awardedAt DateTime @default(now()) @map("awarded_at")

  user User @relation("userBadges", fields: [userLogin], references: [login], onDelete: Cascade, onUpdate: Cascade)

  // Un joueur ne peut détenir qu'un exemplaire d'un badge donné par discipline.
  @@unique([userLogin, code, game])
  @@index([userLogin])
  @@map("user_badges")
}

model Notification {
  id             String   @id @default(uuid())
  recipientLogin String   @map("recipient_login")
  type           String   // 'challenge_received' | 'match_result' | 'tournament' | 'ops_targeted' | 'new_player' | …
  title          String
  body           String?
  link           String?  // route front contextuelle (ex. '/challenges')
  read           Boolean  @default(false)
  createdAt      DateTime @default(now()) @map("created_at")

  recipient User @relation("notif", fields: [recipientLogin], references: [login], onDelete: Cascade, onUpdate: Cascade)

  @@index([recipientLogin, read])
  @@index([recipientLogin, createdAt])
  @@map("notifications")
}

model FeatureRequest {
  id        String   @id @default(uuid())
  text      String
  status    String   @default("pending") // 'pending' | 'accepted' | 'rejected'
  authorId  String   @map("author_id")
  createdAt DateTime @default(now()) @map("created_at")

  author User @relation(fields: [authorId], references: [login])

  @@map("feature_requests")
}

model BugReport {
  id        String   @id @default(uuid())
  text      String
  status    String   @default("open") // 'open' | 'resolved' | 'closed'
  authorId  String   @map("author_id")
  createdAt DateTime @default(now()) @map("created_at")

  author User @relation(fields: [authorId], references: [login])

  @@map("bug_reports")
}

model RejectedMatch {
  id             String   @id @default(uuid())
  declarerLogin  String   @map("declarer_login")
  opponentLogin  String   @map("opponent_login")
  scoreDeclarer  Int      @map("score_declarer")
  scoreOpponent  Int      @map("score_opponent")
  contestReason  String   @map("contest_reason")
  contestMessage String   @map("contest_message")
  rejectedAt     DateTime @default(now()) @map("rejected_at")

  declarer User @relation("rejectedDeclarer", fields: [declarerLogin], references: [login])
  opponent User @relation("rejectedOpponent", fields: [opponentLogin], references: [login])

  @@index([declarerLogin])
  @@index([opponentLogin])
  @@map("rejected_matches")
}

model Ops {
  id          String   @id @default(uuid())
  ownerLogin  String   @map("owner_login")
  targetLogin String   @map("target_login")
  declaredAt  DateTime @default(now()) @map("declared_at")
  expiresAt   DateTime @map("expires_at")
  // Nombre de matchs forcés déjà consommés (joués ou refusés) sur cet OPS.
  // La cible ne peut pas refuser tant que forcedUsed < OPS_FORCED_MATCHES (3).
  forcedUsed  Int      @default(0) @map("forced_used")

  owner  User @relation("opsOwner", fields: [ownerLogin], references: [login])
  target User @relation("opsTarget", fields: [targetLogin], references: [login])

  @@index([ownerLogin, expiresAt])
  @@index([targetLogin, expiresAt])
  @@map("ops")
}

model Tournament {
  id            String   @id @default(uuid())
  name          String
  kind          String   @default("friendly")  // 'friendly' | 'official'
  isPrivate     Boolean  @default(false) @map("is_private") // privé = visible/rejoignable sur invitation uniquement
  imageUrl      String?  @map("image_url") // image de couverture optionnelle (URL) ; sinon visuel par défaut généré
  capacity      Int      // nombre de joueurs (>= 6) ; phase de poule activée à partir de 12
  format        String   @default("elimination") // 'elimination' (bracket direct) | 'pools' (poules puis bracket)
  game          String   @default("babyfoot") // 'babyfoot' | 'smash'
  status        String   // 'registration' | 'in_progress' | 'finished' | 'cancelled'
  createdByLogin String  @map("created_by_login")
  winnerLogin   String?  @map("winner_login")
  createdAt     DateTime @default(now()) @map("created_at")
  startedAt     DateTime? @map("started_at")
  finishedAt    DateTime? @map("finished_at")

  createdBy User               @relation("tournamentCreator", fields: [createdByLogin], references: [login])
  winner    User?              @relation("tournamentWinner", fields: [winnerLogin], references: [login])
  entries   TournamentEntry[]
  matches   TournamentMatch[]
  invites   TournamentInvite[]

  @@index([status])
  @@map("tournaments")
}

model TournamentInvite {
  id           String    @id @default(uuid())
  tournamentId String    @map("tournament_id")
  inviterLogin String    @map("inviter_login")
  inviteeLogin String    @map("invitee_login")
  status       String    @default("pending") // 'pending' | 'accepted' | 'declined'
  createdAt    DateTime  @default(now()) @map("created_at")
  decidedAt    DateTime? @map("decided_at")

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  inviter    User       @relation("tournamentInvitesSent",     fields: [inviterLogin], references: [login], onDelete: Cascade)
  invitee    User       @relation("tournamentInvitesReceived", fields: [inviteeLogin], references: [login], onDelete: Cascade)

  @@unique([tournamentId, inviteeLogin])
  @@index([inviteeLogin, status])
  @@index([tournamentId])
  @@map("tournament_invites")
}

model TournamentEntry {
  tournamentId String   @map("tournament_id")
  login        String
  joinedAt     DateTime @default(now()) @map("joined_at")

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [login], references: [login])

  @@id([tournamentId, login])
  @@map("tournament_entries")
}

model TournamentMatch {
  id            String   @id @default(uuid())
  tournamentId  String   @map("tournament_id")
  stage         String   @default("bracket") // 'pool' | 'bracket'
  poolIndex     Int?     @map("pool_index") // index de poule (stage='pool')
  round         Int      // bracket: 1,2,3... ; pool: 0
  slot          Int      // position in the round (0-indexed) ; pool: index global
  playerALogin  String?  @map("player_a_login")
  playerBLogin  String?  @map("player_b_login")
  scoreA        Int?     @map("score_a")
  scoreB        Int?     @map("score_b")
  winnerLogin   String?  @map("winner_login")
  recordedByLogin String? @map("recorded_by_login")
  recordedAt    DateTime? @map("recorded_at")
  confirmedAt   DateTime? @map("confirmed_at")

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  playerA    User?      @relation("tournPlayerA", fields: [playerALogin], references: [login])
  playerB    User?      @relation("tournPlayerB", fields: [playerBLogin], references: [login])

  @@unique([tournamentId, round, slot])
  @@index([tournamentId, round])
  @@map("tournament_matches")
}

model Challenge {
  id              String    @id @default(uuid())
  challengerLogin String    @map("challenger_login")
  opponentLogin   String    @map("opponent_login")
  status          String    // 'pending' | 'accepted' | 'declined' | 'recorded' | 'cancelled'
  game            String    @default("babyfoot") // 'babyfoot' | 'smash'
  scheduledAt     DateTime  @map("scheduled_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  decidedAt       DateTime? @map("decided_at")

  challenger User @relation("challenger", fields: [challengerLogin], references: [login])
  opponent   User @relation("opponentChallenge", fields: [opponentLogin], references: [login])

  @@index([opponentLogin, status])
  @@index([challengerLogin, status])
  @@map("challenges")
}

model PendingMatch {
  id              String   @id @default(uuid())
  declarerLogin   String   @map("declarer_login")
  opponentLogin   String   @map("opponent_login")
  scoreDeclarer   Int      @map("score_declarer")
  scoreOpponent   Int      @map("score_opponent")
  declaredAt      DateTime @default(now()) @map("declared_at")
  // Multi-jeu : babyfoot par défaut ; champs smash optionnels.
  game            String   @default("babyfoot")
  bestOf          Int?     @map("best_of")
  charDeclarer    String?  @map("char_declarer")
  charOpponent    String?  @map("char_opponent")
  stocks          Int?     // vies restantes du gagnant au game décisif
  // 2v2 Babyfoot — présent uniquement quand mode = '2v2'.
  // partner1Login = coéquipier du déclarant ; partner2Login = coéquipier de l'adversaire.
  mode            String?  // null | '2v2'
  partner1Login   String?  @map("partner_1_login")
  partner2Login   String?  @map("partner_2_login")

  declarer User  @relation("declarer",        fields: [declarerLogin], references: [login])
  opponent User  @relation("opponent",        fields: [opponentLogin], references: [login])
  partner1 User? @relation("pendingPartner1", fields: [partner1Login], references: [login])
  partner2 User? @relation("pendingPartner2", fields: [partner2Login], references: [login])

  @@index([opponentLogin])
  @@map("pending_matches")
}

model PlayedMatch {
  id            String   @id
  playerALogin  String   @map("player_a_login")
  playerBLogin  String   @map("player_b_login")
  scoreA        Int      @map("score_a")
  scoreB        Int      @map("score_b")
  winner        String   // 'A' or 'B'
  playedAt      DateTime @map("played_at")
  countedForElo Boolean  @map("counted_for_elo")
  deltaA        Int      @map("delta_a")
  deltaB        Int      @map("delta_b")
  seasonId      String?  @map("season_id") // saison à laquelle appartient ce match
  // Multi-jeu : babyfoot par défaut ; champs smash optionnels.
  game          String   @default("babyfoot")
  bestOf        Int?     @map("best_of")
  charA         String?  @map("char_a")
  charB         String?  @map("char_b")
  stocksA       Int?     @map("stocks_a")
  stocksB       Int?     @map("stocks_b")
  // 2v2 Babyfoot — présent uniquement quand mode = '2v2'.
  // playerA/B restent les « premiers » joueurs (déclarant canonique et adversaire canonique).
  // playerA2/B2 sont leurs coéquipiers. teamA/B sont les entités duo.
  mode          String?  // null | '2v2'
  playerA2Login String?  @map("player_a2_login")
  playerB2Login String?  @map("player_b2_login")
  deltaA2       Int?     @map("delta_a2")
  deltaB2       Int?     @map("delta_b2")
  teamAId       String?  @map("team_a_id")
  teamBId       String?  @map("team_b_id")

  playerA User          @relation("playerA",  fields: [playerALogin],  references: [login])
  playerB User          @relation("playerB",  fields: [playerBLogin],  references: [login])
  playerA2 User?        @relation("playerA2", fields: [playerA2Login], references: [login])
  playerB2 User?        @relation("playerB2", fields: [playerB2Login], references: [login])
  teamA    BabyfootTeam? @relation("playedMatchTeamA", fields: [teamAId], references: [id])
  teamB    BabyfootTeam? @relation("playedMatchTeamB", fields: [teamBId], references: [id])

  @@index([playerALogin, playerBLogin, playedAt])
  @@index([seasonId])
  @@map("played_matches")
}

// ─── Babyfoot 2v2 ─────────────────────────────────────────────────────────────
//
// Un BabyfootTeam représente un duo de joueurs stable dans le mode 2v2 du Babyfoot.
// Les duos sont créés silencieusement lors de la validation du premier match 2v2.
// player1Login < player2Login (tri lexicographique) — clé canonique qui garantit
// l'unicité : les duos (A, B) et (B, A) pointent toujours sur la même ligne.
//
// L'ELO initial est pondéré (65 % / 35 %) pour refléter l'influence du joueur fort
// (cf. `initTeamElo` dans packages/shared/src/elo2v2.ts).
model BabyfootTeam {
  id            String   @id @default(uuid())
  player1Login  String   @map("player_1_login") // login canoniquement "inférieur"
  player2Login  String   @map("player_2_login") // login canoniquement "supérieur"
  elo           Int      @default(1000)
  name          String?  // surnom optionnel du duo, défini par les joueurs
  createdAt     DateTime @default(now()) @map("created_at")

  player1        User          @relation("babyfootTeamPlayer1", fields: [player1Login], references: [login])
  player2        User          @relation("babyfootTeamPlayer2", fields: [player2Login], references: [login])
  matchesAsTeamA PlayedMatch[] @relation("playedMatchTeamA")
  matchesAsTeamB PlayedMatch[] @relation("playedMatchTeamB")

  // La paire (player1, player2) est la clé métier : unique et toujours triée.
  @@unique([player1Login, player2Login])
  @@index([player1Login])
  @@index([player2Login])
  @@map("babyfoot_teams")
}

model Season {
  id        String    @id @default(uuid())
  name      String
  isActive  Boolean   @default(false) @map("is_active")
  startedAt DateTime  @default(now()) @map("started_at")
  endedAt   DateTime? @map("ended_at")

  @@map("seasons")
}

// Snapshot du classement final d'une saison (figé à la clôture).
model SeasonStanding {
  id       String @id @default(uuid())
  seasonId String @map("season_id")
  game     String @default("babyfoot") // discipline du classement figé
  login    String
  rank     Int
  elo      Int
  wins     Int
  losses   Int

  @@index([seasonId])
  @@index([login])
  @@map("season_standings")
}

enum AdminAction {
  SET_ROLE
  BAN_USER
  UNBAN_USER
  EDIT_STATS
  EDIT_TITLE
  DELETE_MATCH
  EDIT_MATCH
  REFRESH_IMAGES
  RESET_DATABASE
  DELETE_CHALLENGE
  DELETE_PENDING_MATCH
  DELETE_REJECTED_MATCH
  DELETE_OPS
  DELETE_TOURNAMENT
  IMPERSONATE_TESTER
}

model AdminAuditLog {
  id          String      @id @default(uuid())
  actorLogin  String      @map("actor_login")
  actorRole   Role        @map("actor_role")
  action      AdminAction
  targetLogin String?     @map("target_login")
  payload     Json?
  ipAddress   String?     @map("ip_address")
  userAgent   String?     @map("user_agent")
  createdAt   DateTime    @default(now()) @map("created_at")

  @@index([createdAt(sort: Desc)])
  @@index([actorLogin])
  @@index([targetLogin])
  @@map("admin_audit_log")
}

// ─── Boutique « League Coin » ──────────────────────────────────────────────────
//
// Catalogue d'objets cosmétiques achetables avec des League Coins. Le `payload`
// JSON porte les données spécifiques à la catégorie (titre → {"title":"…"} ;
// bannière → {"gradient":"…"}). Un objet inactif disparaît de la boutique mais
// reste possédé par ceux qui l'ont déjà acheté.
model ShopItem {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  description String?
  category    String   // 'title' | 'banner' | 'cosmetic'
  price       Int      // en League Coins
  payload     Json?    // title -> {"title":"Pionnier"} ; banner -> {"gradient":"..."}
  active      Boolean  @default(true)
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  inventory   ShopInventory[]
  @@map("shop_items")
}

// Inventaire : objets possédés par un joueur. `equipped` = objet actuellement
// porté (au plus un équipé par catégorie, cf. logique d'équipement dans index.ts).
model ShopInventory {
  userLogin  String   @map("user_login")
  itemId     String   @map("item_id")
  equipped   Boolean  @default(false)
  acquiredAt DateTime @default(now()) @map("acquired_at")
  user User     @relation("userInventory", fields: [userLogin], references: [login], onDelete: Cascade, onUpdate: Cascade)
  item ShopItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  @@id([userLogin, itemId])
  @@index([userLogin])
  @@map("shop_inventory")
}

// ─── Matchmaking ───────────────────────────────────────────────────────────────
//
// File d'attente du matchmaking : une seule entrée par joueur (clé = login). Le
// `game` est la discipline pour laquelle le joueur cherche un adversaire. Lors
// d'un /queue/join, on apparie le joueur avec le plus ancien autre joueur de la
// même discipline puis on retire les deux entrées.
model MatchmakingQueue {
  login    String   @id
  game     String
  joinedAt DateTime @default(now()) @map("joined_at")

  @@map("matchmaking_queue")
}
