generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  MODERATOR
  ADMIN
  SUPERADMIN
}

model User {
  login               String    @id
  ftId                Int?      @unique @map("ft_id")
  campus              String?
  // Identité réelle issue du profil 42 — affichée à la place du login (le front
  // construit « prénom nom » et retombe sur le login si absent).
  firstName           String?   @map("first_name")
  lastName            String?   @map("last_name")
  imageUrl            String?   @map("image_url")
  title               String?
  role                Role      @default(USER)
  elo                 Int       @default(1000)
  matchesPlayed       Int       @default(0) @map("matches_played")
  dodgeCount          Int       @default(0) @map("dodge_count")
  tournamentsWon      Int       @default(0) @map("tournaments_won")
  // Classement Smash Bros (jeu parallèle) — rating/compteurs distincts du babyfoot.
  eloSmash            Int       @default(1000) @map("elo_smash")
  matchesPlayedSmash  Int       @default(0) @map("matches_played_smash")
  tournamentsWonSmash Int       @default(0) @map("tournaments_won_smash")
  // Classement Échecs (3e discipline).
  eloChess            Int       @default(1000) @map("elo_chess")
  matchesPlayedChess  Int       @default(0) @map("matches_played_chess")
  tournamentsWonChess Int       @default(0) @map("tournaments_won_chess")
  // Classement Street Fighter (4e discipline, mécaniquement identique au Smash).
  eloSf               Int       @default(1000) @map("elo_sf")
  matchesPlayedSf     Int       @default(0) @map("matches_played_sf")
  tournamentsWonSf    Int       @default(0) @map("tournaments_won_sf")
  // Classement Fléchettes (5e discipline — multijoueur 301/501, pas de tournoi).
  eloFlechettes            Int  @default(1000) @map("elo_flechettes")
  matchesPlayedFlechettes  Int  @default(0) @map("matches_played_flechettes")
  tournamentsWonFlechettes Int  @default(0) @map("tournaments_won_flechettes")
  // Porte-monnaie « League Coin » — solde dépensable dans la boutique (cf. ShopItem).
  leagueCoins         Int       @default(0) @map("league_coins")
  // Modes auxquels le joueur adhère (apparaît dans les stats/classements du mode).
  games               String[]  @default(["babyfoot"])
  // Personnages favoris (« mains ») par jeu de combat — ids des rosters front
  // (SMASH_ROSTER / SF_ROSTER), ordonnés. Affichés sur le profil et épinglés en
  // haut du sélecteur de perso lors d'une déclaration de match.
  favSmash            String[]  @default([]) @map("fav_smash")
  favSf               String[]  @default([]) @map("fav_sf")
  onboardedAt         DateTime? @map("onboarded_at") // a choisi ses modes (1er login)
  bannedAt            DateTime? @map("banned_at")
  anonymizedAt        DateTime? @map("anonymized_at")
  deletionScheduledAt DateTime? @map("deletion_scheduled_at")
  // Preuve du consentement RGPD (CGU API 42, Art. 4.2). `termsAcceptedAt` = date
  // d'acceptation ; `termsVersion` = version de la politique acceptée. Si la
  // politique évolue, termsVersion ne correspond plus → le consentement est
  // re-demandé. Tant que le consentement n'est pas donné, la consent-gate
  // (cf. index.ts) refuse tout traitement de données 42 côté serveur (403).
  termsAcceptedAt     DateTime? @map("terms_accepted_at")
  termsVersion        String?   @map("terms_version")
  // Accès staging : flag indépendant du rôle. Positionné par /admin/users/:login/staging-access.
  stagingAllowed      Boolean   @default(false) @map("staging_allowed")
  // Permissions granulaires d'un MODERATOR (null = aucune permission). Voir ModeratorPermission.
  moderatorPermissions Json?    @map("moderator_permissions")
  createdAt           DateTime  @default(now()) @map("created_at")

  declaredPending           PendingMatch[]          @relation("declarer")
  awaitingPending           PendingMatch[]          @relation("opponent")
  matchesAsA                PlayedMatch[]           @relation("playerA")
  matchesAsB                PlayedMatch[]           @relation("playerB")
  // 2v2 Babyfoot — second player of each team side.
  matchesAsA2               PlayedMatch[]           @relation("playerA2")
  matchesAsB2               PlayedMatch[]           @relation("playerB2")
  pendingAsPartner1         PendingMatch[]          @relation("pendingPartner1")
  pendingAsPartner2         PendingMatch[]          @relation("pendingPartner2")
  challengesSent            Challenge[]             @relation("challenger")
  challengesReceived        Challenge[]             @relation("opponentChallenge")
  tournamentsCreated        Tournament[]            @relation("tournamentCreator")
  tournamentsWonRel         Tournament[]            @relation("tournamentWinner")
  tournamentEntries         TournamentEntry[]
  tournamentMatchesA        TournamentMatch[]       @relation("tournPlayerA")
  tournamentMatchesB        TournamentMatch[]       @relation("tournPlayerB")
  opsAsOwner                Ops[]                   @relation("opsOwner")
  opsAsTarget               Ops[]                   @relation("opsTarget")
  tournamentInvitesSent     TournamentInvite[]      @relation("tournamentInvitesSent")
  tournamentInvitesReceived TournamentInvite[]      @relation("tournamentInvitesReceived")
  featureRequests           FeatureRequest[]
  bugReports                BugReport[]
  rejectedAsDeclarer        RejectedMatch[]         @relation("rejectedDeclarer")
  rejectedAsOpponent        RejectedMatch[]         @relation("rejectedOpponent")
  notifications             Notification[]          @relation("notif")
  badges                    UserBadge[]             @relation("userBadges")
  following                 Follow[]                @relation("following")
  followers                 Follow[]                @relation("followers")
  // BabyfootTeam — duos 2v2 dont ce joueur fait partie.
  babyfootTeamsAsP1         BabyfootTeam[]          @relation("babyfootTeamPlayer1")
  babyfootTeamsAsP2         BabyfootTeam[]          @relation("babyfootTeamPlayer2")
  // Boutique — cosmétiques possédés par le joueur (titres, bannières…).
  inventory                 ShopInventory[]         @relation("userInventory")
  // Smash FFA (Free-For-All) — déclarations et participations.
  ffaDeclared               PendingFfa[]            @relation("ffaDeclarer")
  ffaPendingParticipant     PendingFfaParticipant[] @relation("ffaPendingParticipant")
  ffaPlayedParticipant      PlayedFfaParticipant[]  @relation("ffaPlayedParticipant")
  // Économie de coins — progression des quêtes hebdo + paris placés.
  weeklyQuests              WeeklyQuestProgress[]   @relation("userQuests")
  bets                      Bet[]                   @relation("userBets")
  analyticsEvents           AnalyticsEvent[]        @relation("userAnalytics")

  @@map("users")
}

model Follow {
  id               String   @id @default(uuid())
  followerLogin    String   @map("follower_login")
  followeeLogin    String   @map("followee_login")
  // Préférences de notification par personne suivie.
  notifyTournament Boolean  @default(true) @map("notify_tournament")
  notifyTop3       Boolean  @default(true) @map("notify_top3")
  notifyTrophy     Boolean  @default(true) @map("notify_trophy")
  notifyOps        Boolean  @default(true) @map("notify_ops")
  createdAt        DateTime @default(now()) @map("created_at")

  follower User @relation("following", fields: [followerLogin], references: [login], onDelete: Cascade, onUpdate: Cascade)
  followee User @relation("followers", fields: [followeeLogin], references: [login], onDelete: Cascade, onUpdate: Cascade)

  @@unique([followerLogin, followeeLogin])
  @@index([followeeLogin])
  @@map("follows")
}

model UserBadge {
  id        String   @id @default(uuid())
  userLogin String   @map("user_login")
  code      String // code du badge (cf. catalogue front), ex. 'beta_tester', 'season_champion'
  seasonId  String?  @map("season_id") // saison associée (badges de palmarès), si pertinent
  // Discipline liée ('' = badge global, 'babyfoot'/'smash'/'chess' = spécifique).
  // Permet de distinguer un champion babyfoot et un champion chess sur la même saison.
  game      String   @default("") // '' | 'babyfoot' | 'smash' | 'chess'
  awardedAt DateTime @default(now()) @map("awarded_at")

  user User @relation("userBadges", fields: [userLogin], references: [login], onDelete: Cascade, onUpdate: Cascade)

  // Un joueur ne peut détenir qu'un exemplaire d'un badge donné par discipline.
  @@unique([userLogin, code, game])
  @@index([userLogin])
  @@map("user_badges")
}

model Notification {
  id             String   @id @default(uuid())
  recipientLogin String   @map("recipient_login")
  type           String // 'challenge_received' | 'match_result' | 'tournament' | 'ops_targeted' | 'new_player' | …
  // Jeu d'origine (babyfoot|smash|chess|streetfighter) : pilote la couleur de
  // fond + l'emoji de la cloche et la bascule de mode au clic. Null pour les
  // notifs transverses (nouveau joueur, OPS…).
  game           String?
  title          String
  body           String?
  link           String? // route front contextuelle (ex. '/challenges')
  // Entité liée (pendingMatch / playedMatch / challenge). Permet de marquer la
  // notif « lue » automatiquement quand l'action sous-jacente est traitée
  // (score validé/contesté…), pour ne pas la laisser traîner dans la cloche.
  refId          String?  @map("ref_id")
  read           Boolean  @default(false)
  createdAt      DateTime @default(now()) @map("created_at")

  recipient User @relation("notif", fields: [recipientLogin], references: [login], onDelete: Cascade, onUpdate: Cascade)

  @@index([recipientLogin, read])
  @@index([recipientLogin, createdAt])
  @@index([recipientLogin, refId])
  @@map("notifications")
}

model FeatureRequest {
  id        String   @id @default(uuid())
  text      String
  status    String   @default("pending") // 'pending' | 'accepted' | 'rejected'
  authorId  String   @map("author_id")
  createdAt DateTime @default(now()) @map("created_at")

  author User @relation(fields: [authorId], references: [login])

  @@map("feature_requests")
}

model BugReport {
  id        String   @id @default(uuid())
  text      String
  status    String   @default("open") // 'open' | 'resolved' | 'closed'
  authorId  String   @map("author_id")
  createdAt DateTime @default(now()) @map("created_at")

  author User @relation(fields: [authorId], references: [login])

  @@map("bug_reports")
}

model RejectedMatch {
  id             String   @id @default(uuid())
  declarerLogin  String   @map("declarer_login")
  opponentLogin  String   @map("opponent_login")
  scoreDeclarer  Int      @map("score_declarer")
  scoreOpponent  Int      @map("score_opponent")
  contestReason  String   @map("contest_reason")
  contestMessage String   @map("contest_message")
  rejectedAt     DateTime @default(now()) @map("rejected_at")

  declarer User @relation("rejectedDeclarer", fields: [declarerLogin], references: [login])
  opponent User @relation("rejectedOpponent", fields: [opponentLogin], references: [login])

  @@index([declarerLogin])
  @@index([opponentLogin])
  @@map("rejected_matches")
}

model Ops {
  id          String   @id @default(uuid())
  ownerLogin  String   @map("owner_login")
  targetLogin String   @map("target_login")
  declaredAt  DateTime @default(now()) @map("declared_at")
  expiresAt   DateTime @map("expires_at")
  // Nombre de matchs forcés déjà consommés (joués ou refusés) sur cet OPS.
  // La cible ne peut pas refuser tant que forcedUsed < OPS_FORCED_MATCHES (3).
  forcedUsed  Int      @default(0) @map("forced_used")

  owner  User @relation("opsOwner", fields: [ownerLogin], references: [login])
  target User @relation("opsTarget", fields: [targetLogin], references: [login])

  @@index([ownerLogin, expiresAt])
  @@index([targetLogin, expiresAt])
  @@map("ops")
}

model Tournament {
  id             String    @id @default(uuid())
  name           String
  kind           String    @default("friendly") // 'friendly' | 'official'
  isPrivate      Boolean   @default(false) @map("is_private") // privé = visible/rejoignable sur invitation uniquement
  imageUrl       String?   @map("image_url") // image de couverture optionnelle (URL) ; sinon visuel par défaut généré
  capacity       Int // 1v1 : nombre de joueurs ; 2v2 : nombre d'ÉQUIPES. Poules dès 12.
  // '1v1' (un login par côté) | '2v2' (babyfoot doubles : chaque entrée = une paire,
  // représentée dans le bracket par le login « capitaine », cf. partnerLogin).
  mode           String    @default("1v1")
  format         String    @default("elimination") // 'elimination' (bracket direct) | 'pools' (poules puis bracket)
  game           String    @default("babyfoot") // 'babyfoot' | 'smash'
  status         String // 'registration' | 'in_progress' | 'finished' | 'cancelled'
  createdByLogin String    @map("created_by_login")
  winnerLogin    String?   @map("winner_login")
  createdAt      DateTime  @default(now()) @map("created_at")
  startedAt      DateTime? @map("started_at")
  finishedAt     DateTime? @map("finished_at")
  // Match « en cours » désigné par l'organisateur (« match suivant ») : déclenche
  // l'écran VERSUS chez tous les spectateurs et met le duel en avant dans l'arbre.
  // Sans objet pour les échecs (matchs en parallèle). Effacé à la confirmation.
  activeMatchId  String?   @map("active_match_id")

  // Récompense du vainqueur (tournois officiels) : 'none' | 'coins' | 'cosmetic'.
  // 'cosmetic' référence un ShopItem (existant, ou créé inline en active:false →
  // masqué de la boutique). Versée une seule fois au settlement de la finale.
  prizeKind   String  @default("none") @map("prize_kind")
  prizeCoins  Int?    @map("prize_coins")
  prizeItemId String? @map("prize_item_id")

  // ── Économie des paris & cash-prize (cf. tournament-economy.ts) ──────────────
  // Multiplicateur de gain d'un pari sur le VAINQUEUR du tournoi. Les paliers
  // intermédiaires (passer un tour, demi…) sont interpolés linéairement de 1
  // (0 tour franchi → mise perdue) jusqu'à ce final. Amicaux : 2. Officiels : 2..10.
  betFinalMult Int @default(2) @map("bet_final_mult")
  // Cash-prize (coins) du CHAMPION pour un tournoi officiel. Les paliers inférieurs
  // (demi, quart…) sont dérivés proportionnellement au tour atteint. null = pas de
  // cash-prize (amicaux, ou officiel sans dotation).
  cashPrizeBase Int? @map("cash_prize_base")

  createdBy User               @relation("tournamentCreator", fields: [createdByLogin], references: [login])
  winner    User?              @relation("tournamentWinner", fields: [winnerLogin], references: [login])
  prizeItem ShopItem?          @relation("tournamentPrize", fields: [prizeItemId], references: [id], onDelete: SetNull)
  entries   TournamentEntry[]
  matches   TournamentMatch[]
  invites   TournamentInvite[]
  bets      Bet[]              @relation("tournamentBets")

  @@index([status])
  @@map("tournaments")
}

model TournamentInvite {
  id           String    @id @default(uuid())
  tournamentId String    @map("tournament_id")
  inviterLogin String    @map("inviter_login")
  inviteeLogin String    @map("invitee_login")
  status       String    @default("pending") // 'pending' | 'accepted' | 'declined'
  createdAt    DateTime  @default(now()) @map("created_at")
  decidedAt    DateTime? @map("decided_at")

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  inviter    User       @relation("tournamentInvitesSent", fields: [inviterLogin], references: [login], onDelete: Cascade)
  invitee    User       @relation("tournamentInvitesReceived", fields: [inviteeLogin], references: [login], onDelete: Cascade)

  @@unique([tournamentId, inviteeLogin])
  @@index([inviteeLogin, status])
  @@index([tournamentId])
  @@map("tournament_invites")
}

model TournamentEntry {
  tournamentId String   @map("tournament_id")
  login        String // 1v1 : le joueur. 2v2 : le « capitaine » (login canonique) de la paire.
  // 2v2 uniquement : coéquipier du capitaine. Stocké en simple login (pas de relation)
  // pour éviter d'alourdir le modèle User. Un login n'apparaît qu'une fois par tournoi
  // (ni deux fois capitaine, ni capitaine+partenaire) — garanti côté route.
  partnerLogin String?  @map("partner_login")
  joinedAt     DateTime @default(now()) @map("joined_at")

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [login], references: [login])

  @@id([tournamentId, login])
  @@map("tournament_entries")
}

model TournamentMatch {
  id              String    @id @default(uuid())
  tournamentId    String    @map("tournament_id")
  stage           String    @default("bracket") // 'pool' | 'bracket'
  poolIndex       Int?      @map("pool_index") // index de poule (stage='pool')
  round           Int // bracket: 1,2,3... ; pool: 0
  slot            Int // position in the round (0-indexed) ; pool: index global
  playerALogin    String?   @map("player_a_login")
  playerBLogin    String?   @map("player_b_login")
  scoreA          Int?      @map("score_a")
  scoreB          Int?      @map("score_b")
  winnerLogin     String?   @map("winner_login")
  recordedByLogin String?   @map("recorded_by_login")
  recordedAt      DateTime? @map("recorded_at")
  confirmedAt     DateTime? @map("confirmed_at")
  // Verrou de paris : posé au PREMIER score saisi sur ce match, JAMAIS remis à
  // null (même si le score est ensuite rejeté/réinitialisé). Empêche la
  // réouverture du marché de paris une fois qu'un score a été divulgué.
  betsLockedAt    DateTime? @map("bets_locked_at")
  // Pile-ou-face d'avant-duel : désigne qui choisit son avantage (résultat partagé).
  tossWinnerLogin String?   @map("toss_winner_login") // gagnant du pile-ou-face
  tossSide        String?   @map("toss_side") // 'heads' | 'tails' (face affichée par l'anim)
  advantagePick   String?   @map("advantage_pick") // clé d'option choisie par le gagnant du toss
  tossAt          DateTime? @map("toss_at")

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  playerA    User?      @relation("tournPlayerA", fields: [playerALogin], references: [login])
  playerB    User?      @relation("tournPlayerB", fields: [playerBLogin], references: [login])

  @@unique([tournamentId, round, slot])
  @@index([tournamentId, round])
  @@map("tournament_matches")
}

model Challenge {
  id              String    @id @default(uuid())
  challengerLogin String    @map("challenger_login")
  opponentLogin   String    @map("opponent_login")
  status          String // 'pending' | 'accepted' | 'declined' | 'recorded' | 'cancelled'
  game            String    @default("babyfoot") // 'babyfoot' | 'smash'
  scheduledAt     DateTime  @map("scheduled_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  decidedAt       DateTime? @map("decided_at")

  // 2v2 Babyfoot (mode = '2v2') : le challenger nomme les 4 joueurs ; seuls les
  // DEUX adversaires acceptent (un timestamp chacun) → 'accepted' quand les deux.
  mode                      String?   // null | '2v2'
  partnerLogin              String?   @map("partner_login") // coéquipier du challenger
  opponentPartnerLogin      String?   @map("opponent_partner_login") // coéquipier de l'adversaire
  opponentAcceptedAt        DateTime? @map("opponent_accepted_at")
  opponentPartnerAcceptedAt DateTime? @map("opponent_partner_accepted_at")

  challenger User @relation("challenger", fields: [challengerLogin], references: [login])
  opponent   User @relation("opponentChallenge", fields: [opponentLogin], references: [login])

  @@index([opponentLogin, status])
  @@index([challengerLogin, status])
  @@map("challenges")
}

model PendingMatch {
  id            String   @id @default(uuid())
  declarerLogin String   @map("declarer_login")
  opponentLogin String   @map("opponent_login")
  scoreDeclarer Int      @map("score_declarer")
  scoreOpponent Int      @map("score_opponent")
  declaredAt    DateTime @default(now()) @map("declared_at")
  // Multi-jeu : babyfoot par défaut ; champs smash optionnels.
  game          String   @default("babyfoot")
  bestOf        Int?     @map("best_of")
  charDeclarer  String?  @map("char_declarer")
  charOpponent  String?  @map("char_opponent")
  stocks        Int? // vies restantes du gagnant au game décisif
  // 2v2 Babyfoot — présent uniquement quand mode = '2v2'.
  // partner1Login = coéquipier du déclarant ; partner2Login = coéquipier de l'adversaire.
  mode          String? // null | '2v2'
  partner1Login String?  @map("partner_1_login")
  partner2Login String?  @map("partner_2_login")
  // Confirmations progressives 2v2 — null = n/a (match 1v1).
  // Le déclarant est auto-validé ; les 3 autres valident indépendamment.
  // Settlement déclenché uniquement quand les 3 sont à `true`.
  partner1Confirmed Boolean? @default(false) @map("partner_1_confirmed")
  opp1Confirmed     Boolean? @default(false) @map("opp_1_confirmed")
  opp2Confirmed     Boolean? @default(false) @map("opp_2_confirmed")

  declarer User  @relation("declarer", fields: [declarerLogin], references: [login])
  opponent User  @relation("opponent", fields: [opponentLogin], references: [login])
  partner1 User? @relation("pendingPartner1", fields: [partner1Login], references: [login])
  partner2 User? @relation("pendingPartner2", fields: [partner2Login], references: [login])

  @@index([opponentLogin])
  @@map("pending_matches")
}

model PlayedMatch {
  id            String   @id
  playerALogin  String   @map("player_a_login")
  playerBLogin  String   @map("player_b_login")
  scoreA        Int      @map("score_a")
  scoreB        Int      @map("score_b")
  winner        String // 'A' or 'B'
  playedAt      DateTime @map("played_at")
  countedForElo Boolean  @map("counted_for_elo")
  deltaA        Int      @map("delta_a")
  deltaB        Int      @map("delta_b")
  seasonId      String?  @map("season_id") // saison à laquelle appartient ce match
  // Multi-jeu : babyfoot par défaut ; champs smash optionnels.
  game          String   @default("babyfoot")
  bestOf        Int?     @map("best_of")
  charA         String?  @map("char_a")
  charB         String?  @map("char_b")
  stocksA       Int?     @map("stocks_a")
  stocksB       Int?     @map("stocks_b")
  // 2v2 Babyfoot — présent uniquement quand mode = '2v2'.
  // playerA/B restent les « premiers » joueurs (déclarant canonique et adversaire canonique).
  // playerA2/B2 sont leurs coéquipiers. teamA/B sont les entités duo.
  mode          String? // null | '2v2'
  playerA2Login String?  @map("player_a2_login")
  playerB2Login String?  @map("player_b2_login")
  deltaA2       Int?     @map("delta_a2")
  deltaB2       Int?     @map("delta_b2")
  teamAId       String?  @map("team_a_id")
  teamBId       String?  @map("team_b_id")

  playerA  User          @relation("playerA", fields: [playerALogin], references: [login])
  playerB  User          @relation("playerB", fields: [playerBLogin], references: [login])
  playerA2 User?         @relation("playerA2", fields: [playerA2Login], references: [login])
  playerB2 User?         @relation("playerB2", fields: [playerB2Login], references: [login])
  teamA    BabyfootTeam? @relation("playedMatchTeamA", fields: [teamAId], references: [id])
  teamB    BabyfootTeam? @relation("playedMatchTeamB", fields: [teamBId], references: [id])

  @@index([playerALogin, playerBLogin, playedAt])
  @@index([seasonId])
  @@map("played_matches")
}

// ─── Smash FFA (Free-For-All, 3+ joueurs) ────────────────────────────────────
//
// EXCLUSIF au Smash. Le déclarant propose le CLASSEMENT FINAL complet : chaque
// participant a une `position` (1 = 1er … N = dernier). Le déclarant est
// auto-confirmé ; chaque AUTRE participant confirme UNIQUEMENT sa propre position.
// Une contestation annule tout le FFA (delete cascade). Le settlement (ELO) se
// déclenche quand toutes les positions sont confirmées : l'ELO bouge selon le
// rang (round-robin sensible au rating, cf. calculateFfaElo).
model PendingFfa {
  id            String   @id @default(uuid())
  declarerLogin String   @map("declarer_login")
  game          String   @default("smash")
  // Fléchettes uniquement : score de départ (301 ou 501). null pour le Smash FFA.
  startScore    Int?     @map("start_score")
  declaredAt    DateTime @default(now()) @map("declared_at")

  declarer     User                    @relation("ffaDeclarer", fields: [declarerLogin], references: [login], onDelete: Cascade, onUpdate: Cascade)
  participants PendingFfaParticipant[]

  @@index([declarerLogin])
  @@map("pending_ffas")
}

model PendingFfaParticipant {
  id        String  @id @default(uuid())
  pendingId String  @map("pending_id")
  login     String
  position  Int // 1 = 1er, N = dernier (proposé par le déclarant)
  // Fléchettes uniquement : points RESTANTS du joueur (0 = vainqueur). La position
  // en découle. null pour le Smash FFA (classement par rang seul).
  remaining Int?
  confirmed Boolean @default(false) // le joueur a validé SA position / son reste

  pending PendingFfa @relation(fields: [pendingId], references: [id], onDelete: Cascade)
  user    User       @relation("ffaPendingParticipant", fields: [login], references: [login], onDelete: Cascade, onUpdate: Cascade)

  @@unique([pendingId, login]) // un joueur une seule fois par FFA
  @@unique([pendingId, position]) // positions uniques 1..N
  @@index([login]) // « mes FFA à confirmer »
  @@map("pending_ffa_participants")
}

model PlayedFfa {
  id            String   @id
  game          String   @default("smash")
  // Fléchettes uniquement : score de départ (301/501). null pour le Smash FFA.
  startScore    Int?     @map("start_score")
  playedAt      DateTime @map("played_at")
  seasonId      String?  @map("season_id")
  countedForElo Boolean  @default(true) @map("counted_for_elo")

  participants PlayedFfaParticipant[]

  @@index([seasonId])
  @@index([playedAt])
  @@map("played_ffas")
}

model PlayedFfaParticipant {
  id           String @id @default(uuid())
  playedId     String @map("played_id")
  login        String
  position     Int
  // Fléchettes uniquement : points restants à la fin (0 = vainqueur). null pour Smash.
  remaining    Int?
  ratingBefore Int    @map("rating_before")
  delta        Int
  ratingAfter  Int    @map("rating_after")

  played PlayedFfa @relation(fields: [playedId], references: [id], onDelete: Cascade)
  user   User      @relation("ffaPlayedParticipant", fields: [login], references: [login])

  @@unique([playedId, login])
  @@index([login]) // historique FFA d'un joueur
  @@map("played_ffa_participants")
}

// ─── Babyfoot 2v2 ─────────────────────────────────────────────────────────────
//
// Un BabyfootTeam représente un duo de joueurs stable dans le mode 2v2 du Babyfoot.
// Les duos sont créés silencieusement lors de la validation du premier match 2v2.
// player1Login < player2Login (tri lexicographique) — clé canonique qui garantit
// l'unicité : les duos (A, B) et (B, A) pointent toujours sur la même ligne.
//
// L'ELO initial est pondéré (65 % / 35 %) pour refléter l'influence du joueur fort
// (cf. `initTeamElo` dans packages/shared/src/elo2v2.ts).
model BabyfootTeam {
  id           String   @id @default(uuid())
  player1Login String   @map("player_1_login") // login canoniquement "inférieur"
  player2Login String   @map("player_2_login") // login canoniquement "supérieur"
  elo          Int      @default(1000)
  name         String? // surnom optionnel du duo, défini par les joueurs
  createdAt    DateTime @default(now()) @map("created_at")

  player1        User          @relation("babyfootTeamPlayer1", fields: [player1Login], references: [login])
  player2        User          @relation("babyfootTeamPlayer2", fields: [player2Login], references: [login])
  matchesAsTeamA PlayedMatch[] @relation("playedMatchTeamA")
  matchesAsTeamB PlayedMatch[] @relation("playedMatchTeamB")

  // La paire (player1, player2) est la clé métier : unique et toujours triée.
  @@unique([player1Login, player2Login])
  @@index([player1Login])
  @@index([player2Login])
  @@map("babyfoot_teams")
}

model Season {
  id        String    @id @default(uuid())
  name      String
  isActive  Boolean   @default(false) @map("is_active")
  startedAt DateTime  @default(now()) @map("started_at")
  endedAt   DateTime? @map("ended_at")

  @@map("seasons")
}

// Snapshot du classement final d'une saison (figé à la clôture).
model SeasonStanding {
  id       String @id @default(uuid())
  seasonId String @map("season_id")
  game     String @default("babyfoot") // discipline du classement figé
  login    String
  rank     Int
  elo      Int
  wins     Int
  losses   Int

  @@index([seasonId])
  @@index([login])
  @@map("season_standings")
}

enum AdminAction {
  SET_ROLE
  SET_MODERATOR_PERMISSIONS
  BAN_USER
  UNBAN_USER
  EDIT_STATS
  EDIT_TITLE
  DELETE_MATCH
  EDIT_MATCH
  REFRESH_IMAGES
  RESET_DATABASE
  DELETE_CHALLENGE
  DELETE_PENDING_MATCH
  DELETE_REJECTED_MATCH
  DELETE_OPS
  DELETE_TOURNAMENT
  IMPERSONATE_TESTER
  SYNC_ELO_FROM_PROD
}

model AdminAuditLog {
  id          String      @id @default(uuid())
  actorLogin  String      @map("actor_login")
  actorRole   Role        @map("actor_role")
  action      AdminAction
  targetLogin String?     @map("target_login")
  payload     Json?
  ipAddress   String?     @map("ip_address")
  userAgent   String?     @map("user_agent")
  createdAt   DateTime    @default(now()) @map("created_at")

  @@index([createdAt(sort: Desc)])
  @@index([actorLogin])
  @@index([targetLogin])
  @@map("admin_audit_log")
}

// ─── Boutique « League Coin » ──────────────────────────────────────────────────
//
// Catalogue d'objets cosmétiques achetables avec des League Coins. Le `payload`
// JSON porte les données spécifiques à la catégorie (titre → {"title":"…"} ;
// bannière → {"gradient":"…"}). Un objet inactif disparaît de la boutique mais
// reste possédé par ceux qui l'ont déjà acheté.
model ShopItem {
  id          String          @id @default(uuid())
  name        String
  description String?
  category    String // 'title' | 'banner' | 'badge' | 'cosmetic'
  price       Int // en League Coins
  // Couleur d'accent (hex #rrggbb) — titres & badges. Choisie dans le créateur (Shop GOD).
  color       String?
  // Rareté de l'objet ('common' | 'rare' | 'epic' | 'legendary') — pilote la couleur
  // de la carte en vitrine. Null = rareté déduite du prix (objets antérieurs).
  rarity      String?
  // Données spécifiques à la catégorie :
  //   title  -> {"title":"Pionnier"}
  //   badge  -> {"code":"...","icon":"Crown","label":"..."}
  //   banner -> {"image":"data:image/png;base64,..."} (fond de la carte profil)
  payload     Json?
  active      Boolean         @default(true)
  sortOrder   Int             @default(0) @map("sort_order")
  createdAt   DateTime        @default(now()) @map("created_at")
  inventory   ShopInventory[]
  prizeFor    Tournament[]    @relation("tournamentPrize")

  @@map("shop_items")
}

// Inventaire : objets possédés par un joueur. `equipped` = objet actuellement
// porté (au plus un équipé par catégorie, cf. logique d'équipement dans index.ts).
model ShopInventory {
  userLogin  String   @map("user_login")
  itemId     String   @map("item_id")
  equipped   Boolean  @default(false)
  acquiredAt DateTime @default(now()) @map("acquired_at")
  user       User     @relation("userInventory", fields: [userLogin], references: [login], onDelete: Cascade, onUpdate: Cascade)
  item       ShopItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([userLogin, itemId])
  @@index([userLogin])
  @@map("shop_inventory")
}

// ─── Matchmaking ───────────────────────────────────────────────────────────────
//
// File d'attente du matchmaking : une seule entrée par joueur (clé = login). Le
// `game` est la discipline pour laquelle le joueur cherche un adversaire. Lors
// d'un /queue/join, on apparie le joueur avec le plus ancien autre joueur de la
// même discipline puis on retire les deux entrées.
model MatchmakingQueue {
  login    String
  game     String
  joinedAt DateTime @default(now()) @map("joined_at")

  // Clé composite : un joueur peut être dans la file de PLUSIEURS modes à la fois
  // (une recherche « match aléatoire » indépendante par univers).
  @@id([login, game])
  @@map("matchmaking_queue")
}

// ─── Économie de coins : quêtes hebdomadaires ────────────────────────────────
//
// Une ligne par (joueur, semaine ISO). Les compteurs sont accumulés au règlement
// de chaque match classé (cf. awardMatchEconomyTx). Les quêtes elles-mêmes sont
// définies côté serveur (WEEKLY_QUESTS dans index.ts) et évaluées à la volée à
// partir de ces compteurs ; `claimed` mémorise les ids déjà réclamés (anti
// double-claim). La semaine ISO sert de reset implicite : une nouvelle semaine =
// une nouvelle ligne, donc des compteurs et des réclamations remis à zéro.
model WeeklyQuestProgress {
  login         String
  weekKey       String   @map("week_key") // ex. "2026-W23" (année-semaine ISO 8601)
  matchesPlayed Int      @default(0) @map("matches_played")
  wins          Int      @default(0)
  gamesPlayed   String[] @default([]) @map("games_played") // disciplines distinctes jouées en classé
  claimed       String[] @default([]) // ids de quêtes déjà réclamées cette semaine
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation("userQuests", fields: [login], references: [login], onDelete: Cascade)

  @@id([login, weekKey])
  @@index([login])
  @@map("weekly_quest_progress")
}

// ─── Économie de coins : paris ───────────────────────────────────────────────
//
// Pari à cote fixe ×2 : la mise est débitée à la prise (jamais de solde négatif) ;
// au règlement, un pari gagnant crédite 2× la mise (gain net = mise), un perdant
// ne crédite rien. Cible = vainqueur d'un tournoi ('tournament') OU d'un match de
// bracket précis ('match'). Le règlement a lieu à la confirmation du match de
// tournoi / de la finale ; l'annulation d'un tournoi rembourse les paris ouverts.
model Bet {
  id           String    @id @default(uuid())
  bettorLogin  String    @map("bettor_login")
  targetType   String    @map("target_type") // 'tournament' | 'match'
  tournamentId String    @map("tournament_id") // toujours renseigné (pari match → son tournoi)
  matchId      String?   @map("match_id") // TournamentMatch.id quand targetType='match'
  choiceLogin  String    @map("choice_login") // vainqueur pronostiqué
  stake        Int // mise débitée à la prise
  status       String    @default("open") // 'open' | 'won' | 'lost' | 'refunded'
  payout       Int       @default(0) // coins crédités au règlement (0 si perdu)
  createdAt    DateTime  @default(now()) @map("created_at")
  settledAt    DateTime? @map("settled_at")

  bettor     User       @relation("userBets", fields: [bettorLogin], references: [login], onDelete: Cascade)
  tournament Tournament @relation("tournamentBets", fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([bettorLogin])
  @@index([tournamentId, status])
  @@index([matchId, status])
  @@map("bets")
}

// ─── Analytics : pages vues & événements d'usage (tableau de bord GOD) ────────
//
// Journal léger d'usage *produit* — à ne pas confondre avec AdminAuditLog (actions
// admin). Chaque ligne est soit une page vue ('pageview', name = chemin de route),
// soit une interaction ('event', name = id de bouton/fonctionnalité). `game` porte
// la discipline en contexte quand elle s'applique (null = global). Lié au User en
// cascade : la suppression RGPD d'un compte efface aussi son journal d'usage.
model AnalyticsEvent {
  id        String   @id @default(uuid())
  login     String
  type      String // 'pageview' | 'event'
  name      String // chemin de route (pageview) ou id d'action (event)
  game      String? // 'babyfoot' | 'smash' | 'chess' | 'streetfighter' | 'flechettes' | null
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation("userAnalytics", fields: [login], references: [login], onDelete: Cascade)

  @@index([createdAt(sort: Desc)])
  @@index([type, name])
  @@index([login, createdAt])
  @@map("analytics_events")
}
